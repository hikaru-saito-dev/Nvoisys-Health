{
  "expo": {
    "name": "Nvoisys Health",
    "slug": "nvoisys-health",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/logo_N.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow access to camera for calls and sending photos.",
        "NSMicrophoneUsageDescription": "Allow access to microphone for calls.",
        "NSPhotoLibraryUsageDescription": "Allow access to your photo library to send photos in chat.",
        "NSPhotoLibraryAddUsageDescription": "Allow saving chat photos to your library if needed."
      },
      "bitcode": false,
      "bundleIdentifier": "com.anonymous.myapp"
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#1E1B4B",
        "foregroundImage": "./assets/icons/logo_N.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.myapp",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/logo_N.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1E1B4B",
          "dark": {
            "backgroundColor": "#1E1B4B"
          }
        }
      ],
      "expo-web-browser",
      "expo-notifications",
      "@livekit/react-native-expo-plugin",
      "expo-font",
      "expo-image",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "pbAppointmentsCollection": "appointments",
      "pbAppointmentDoctorIsProfile": true,
      "paymentMode": "cashfree",
      "stripePublishableKey": "",
      "paymentBackendUrl": "https://api.nvoisyshealth.com",
      "cashfreeReturnUrl": "myapp://payment/cashfree",
      "aiBaseUrl": "https://api.groq.com/openai/v1/chat/completions",
      "aiModel": "llama-3.3-70b-versatile",
      "eas": {
        "projectId": "7e784527-38d6-49f6-869a-0bfc8c42812b"
      }
    },
    "owner": "kokoshiro_dev_6"
  }
}
